# ==================== LLM 配置 ====================
# OpenAI API 密钥（从你的 LLM 服务商获取）
OPENAI_API_KEY=your_api_key_here

# OpenAI API 基础 URL（使用兼容 OpenAI 格式的服务商）
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型名称（根据你的服务商提供的模型填写）
OPENAI_MODEL_NAME=gpt-4o-mini

# 可选：嵌入模型（如果使用本地或自定义嵌入模型）
# EMBEDDING_MODEL=your_embedding_model

# LLM 参数
TEMPERATURE=0.7
MAX_TOKENS=65536
MAX_TOKENS_BEFORE_SUMMARY=200000

# ==================== 阿里云 OSS 配置 ====================
# 阿里云 OSS Access Key ID
OSS_AK=your_oss_access_key_id

# 阿里云 OSS Access Key Secret
OSS_SK=your_oss_secret_key

# 剪映项目资源远程路径
PROJECT_REMOTE_PATH=https://your-bucket.oss-region.aliyuncs.com/path/to/projects